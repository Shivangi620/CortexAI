{
    "build": {
        "builder": "dockerfile"
    },
    "deploy": {
        "startCommand": "python -m streamlit run app.py --server.port $PORT --server.headless true --server.address 0.0.0.0",
        "restartPolicyCondition": "on-failure",
        "restartPolicyMaxRetries": 5
    },
    "env": {
        "API_URL": "https://your-backend-url.up.railway.app/api"
    }
}